# App
PROJECT_NAME=Course Manager Backend
API_V1_PREFIX=/api/v1

# Neon / Postgres (ejemplo)
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>/<database>?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=super-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# SMTP global (fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
MAIL_DEFAULT_SENDER=
MAIL_DEFAULT_PASSWORD=

# Clave Fernet para cifrar SMTP de usuarios
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SMTP_CREDENTIALS_KEY=

# IA
AI_MODEL_NAME=simple_nn
